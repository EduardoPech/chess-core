{
  "name": "@pech/chess-core",
  "version": "1.0.0",
  "description": "A fast, type-safe chess library with immutable state and bitboard representation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "chess",
    "bitboard",
    "move-generation",
    "fen",
    "san",
    "uci"
  ],
  "license": "MIT",
  "author": "Eduardo Pech",
  "repository": {
    "type": "git",
    "url": "https://github.com/EduardoPech/chess-core.git"
  },
  "homepage": "https://github.com/EduardoPech/chess-core#readme",
  "bugs": {
    "url": "https://github.com/EduardoPech/chess-core/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
